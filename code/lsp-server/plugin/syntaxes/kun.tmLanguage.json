{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kun",
  "scopeName": "source.kun",
  "fileTypes": ["kun"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#literals" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#strings" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.kun",
          "match": "//.*$"
        }
      ]
    },
    "literals": {
      "patterns": [
        { "name": "string.quoted.double.kun.path", "match": "p\"[^\"]*\"" },
        { "name": "string.quoted.double.kun.regex", "match": "r\"[^\"]*\"" },
        { "name": "string.quoted.double.kun.interpolated", "match": "f\"[^\"]*\"" },
        { "name": "string.quoted.double.kun.multiline", "begin": "\"\"\"", "end": "\"\"\"" },
        { "name": "string.quoted.double.kun.interpolated-multiline", "begin": "f\"\"\"", "end": "\"\"\"" },
        { "name": "constant.numeric.integer.kun", "match": "\\b[0-9][0-9_]*\\b" },
        { "name": "constant.numeric.float.kun", "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b" },
        { "name": "constant.numeric.hex.kun", "match": "\\b0[xXoObB][0-9a-fA-F][0-9a-fA-F_]*\\b" },
        { "name": "constant.language.boolean.kun", "match": "\\b(true|false)\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kun",
          "match": "\\b(case|of|if|then|else|do|in|let|when|defer)\\b"
        },
        {
          "name": "keyword.declaration.kun",
          "match": "\\b(type|import|as|export|main)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.kun",
          "match": "\\b(Int|Float|Bool|String|Bytes|Char|Regex|Duration|Path|Result|List|Set|Map|Stream|Nil)\\b"
        },
        {
          "name": "entity.name.type.kun",
          "match": "\\b[A-Z]\\w*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.kun.pipe", "match": "\\|>" },
        { "name": "keyword.operator.kun.reverse-pipe", "match": "<\\|" },
        { "name": "keyword.operator.kun.compose", "match": ">>|<<" },
        { "name": "keyword.operator.kun.nil-coalescing", "match": "\\?\\?" },
        { "name": "keyword.operator.kun.optional-chain", "match": "\\?\\." },
        { "name": "keyword.operator.kun.arrow", "match": "->" },
        { "name": "keyword.operator.kun.lambda", "match": "\\\\" },
        { "name": "keyword.operator.kun.ternary", "match": "\\?\\s*:" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.kun",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.kun", "match": "\\\\[nrt\"\\\\]" }
      ]
    }
  }
}
