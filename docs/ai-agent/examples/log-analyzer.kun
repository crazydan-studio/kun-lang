import List
import Stream
import String
import Path
import Int
import Result
import DateTime

type LogEntry =
  { timestamp : String
  , level     : String
  , message   : String
  }

parseLine : String -> Result LogEntry String
parseLine = \line ->
  case String.split " " line of
    [ts, lvl, ..rest] ->
      Ok { timestamp = ts, level = lvl, message = String.join " " rest }
    _ ->
      Err f"invalid line: {line}"

getCurrentTime : String ! {DateTime}
getCurrentTime = \ ->
  let
    now = DateTime.now!
  in
    case DateTime.format "HH:mm:ss" now of
      Ok s  -> s
      Err _ -> "??:??:??"

main : List String -> Unit ! {IO, Cmd, DateTime}
main = \args ->
  let
    logPath =
      case args of
        [path] -> Path.fromString path
        _      -> p"/var/log/syslog"

    lines =
      cmd cat {} [ logPath ]
        |> Cmd.stream
        |> Stream.lines
        |> Stream.filterMap Result.ok
        |> Stream.parseMap parseLine
        |> Stream.toList

    errors =
      lines
        |> List.filter (\e -> e.level == "ERROR")

    IO.println f"found {List.length errors} errors at {getCurrentTime!}"
    List.iter
      (\entry ->
        let
          IO.println f"[{entry.timestamp}] {entry.message}"
        in
          ()
      )
      errors
  in
    ()
