{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "kun",
  "scopeName": "source.kun",
  "fileTypes": ["kun"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#strings" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash", "match": "//.*$" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control", "match": "\\b(case|of|if|then|else|do|in|let|when|not|defer)\\b" },
        { "name": "keyword.declaration", "match": "\\b(type|module|import|as|export|main)\\b" },
        { "name": "storage.type", "match": "\\b(Int|Float|Bool|String|Bytes|Char|Regex|Duration|Path|Unit|List|Map|Set|Stream|Result)\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "entity.name.type", "match": "\\b[A-Z][a-zA-Z0-9]*\\b" }
      ]
    },
    "literals": {
      "patterns": [
        { "name": "constant.numeric", "match": "\\b[0-9][0-9_]*[.][0-9_]*([eE][+-]?[0-9]+)?\\b" },
        { "name": "constant.numeric", "match": "\\b0[xXoObB][0-9a-fA-F][0-9a-fA-F_]*\\b" },
        { "name": "constant.numeric.time", "match": "\\b[0-9][0-9_]*(ns|us|ms|[hsmd])\\b" },
        { "name": "constant.numeric", "match": "\\b[0-9][0-9_]*\\b" },
        { "name": "constant.language.boolean", "match": "\\b(true|false)\\b" },
        { "name": "constant.language", "match": "\\b(Nil)\\b" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double", "begin": "f\"\"\"", "end": "\"\"\"" },
        { "name": "string.quoted.double", "begin": "\"\"\"", "end": "\"\"\"" },
        { "name": "string.quoted.double", "match": "f\"[^\"]*\"" },
        { "name": "string.quoted.double", "match": "p\"[^\"]*\"" },
        { "name": "string.quoted.double", "match": "r\"[^\"]*\"" },
        { "name": "string.quoted.double", "match": "\"([^\"]|\\\\\")*\"" },
        { "name": "string.quoted.single", "match": "'[^']*'" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator", "match": "\\|>|<\\||==|/=|<=|>=|->|&&|\\|\\||\\+\\+|\\?\\?|\\?\\.|>>|<<" },
        { "name": "keyword.operator", "match": "\\+|-|\\*|/|%|\\.\\." },
        { "name": "keyword.operator", "match": "#\\{|#\\[" }
      ]
    }
  }
}
