@startuml typesystem-hierarchy
title Kun Type System Hierarchy

package "Base Types" {
  class Int
  class Nat
  class Float
  class Bool
  class String
  class Bytes
  class Char
  class Regex
  class Duration
  class Unit
  class Path
}

package "Compound Types" {
  class "List(T)"
  class "Map(K,V)"
  class "Set(T)"
  class "Stream(T)"
  class Tuple
}

package "Sum Types / ADT" {
  class "Maybe(T)"
  class "Result(T,E)"
  class "Custom ADT"
}

package "Function Types" {
  class "Pure Function"
  class "Command Function"
  class "Higher-Order Function"
}

package "Effect Types" {
  class "IO(T)"
}

package "Type System Infrastructure" {
  class "Kind :: Type"
  class "Kind :: Type -> Type"
  class "Type Variable"
}

"Kind :: Type -> Type" --> "Kind :: Type" : applied to type argument
"List(T)" --> "Kind :: Type -> Type" : List :: Type -> Type
"Maybe(T)" --> "Kind :: Type -> Type" : Maybe :: Type -> Type
"IO(T)" --> "Kind :: Type -> Type" : IO :: Type -> Type

note right of Int : i64, fixed-width
note right of Nat : i64, non-negative only
note right of String : UTF-8, immutable

note bottom of "List(T)" : Rope-based sequence\nindexable, pattern-matchable
note bottom of "Maybe(T)" : Just T | None
note bottom of "Result(T,E)" : Ok T | Err E

@enduml
